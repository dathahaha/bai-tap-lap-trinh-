import math

# Define Point
class Point:
    def __init__(self, x, y):
        self.x = x
        self.y = y

# Define Circle
class Circle:
    def __init__(self, center, radius):
        self.center = center
        self.radius = radius

# Define Rectangle
class Rectangle:
    def __init__(self, corner, width, height):
        self.corner = corner  # bottom-left point
        self.width = width
        self.height = height


# Check if point in circle
def point_in_circle(circle, point):
    dx = point.x - circle.center.x
    dy = point.y - circle.center.y
    distance = math.sqrt(dx**2 + dy**2)
    return distance <= circle.radius


# Get rectangle corners
def rect_corners(rect):
    x, y = rect.corner.x, rect.corner.y
    return [
        Point(x, y),
        Point(x + rect.width, y),
        Point(x, y + rect.height),
        Point(x + rect.width, y + rect.height)
    ]


# Check if rectangle fully inside circle
def rect_in_circle(circle, rect):
    return all(point_in_circle(circle, p) for p in rect_corners(rect))


# Check if rectangle overlaps circle (any corner inside)
def rect_circle_overlap(circle, rect):
    return any(point_in_circle(circle, p) for p in rect_corners(rect))


# ----- Test -----
center = Point(150, 100)
circle = Circle(center, 75)

rect = Rectangle(Point(140, 90), 30, 20)

print("Point in circle:", point_in_circle(circle, Point(150, 100)))
print("Rectangle in circle:", rect_in_circle(circle, rect))
print("Rectangle overlap circle:", rect_circle_overlap(circle, rect))
